{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "no-console": "warn",
    "no-debugger": "warn",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": [
      "warn",
      "always"
    ],
    "curly": "warn",
    "brace-style": [
      "warn",
      "1tbs"
    ],
    "quotes": [
      "warn",
      "single",
      {
        "avoidEscape": true
      }
    ],
    "semi": [
      "warn",
      "always"
    ],
    "indent": [
      "warn",
      2
    ],
    "no-trailing-spaces": "warn",
    "comma-dangle": [
      "warn",
      "es5"
    ]
  },
  "globals": {
    "fetch": "readonly",
    "localStorage": "readonly",
    "sessionStorage": "readonly"
  }
}

